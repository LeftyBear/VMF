```gitignore
# --------------------------------------------------
# Windows
# --------------------------------------------------
Thumbs.db
Desktop.ini

# --------------------------------------------------
# Excel Temporary Files
# --------------------------------------------------
~$*.xls
~$*.xlsx
~$*.xlsm
~$*.xlam
*.tmp

# --------------------------------------------------
# Visual Studio Code
# --------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# --------------------------------------------------
# Logs
# --------------------------------------------------
*.log

# --------------------------------------------------
# Cache
# --------------------------------------------------
.cache/
temp/
tmp/

# --------------------------------------------------
# Backup Files
# --------------------------------------------------
*.bak
*.old
*.orig

# --------------------------------------------------
# Operating System
# --------------------------------------------------
.DS_Store

# --------------------------------------------------
# Build Artifacts (if generated locally)
# --------------------------------------------------
dist/*
!dist/.gitkeep
!dist/debug/
!dist/debug/.gitkeep
!dist/release/
!dist/release/.gitkeep
!dist/release/Build_v1.0.2/
!dist/release/Build_v1.0.2/Build.xlam
/build/

# --------------------------------------------------
# Generated VMF Source Workspace
# --------------------------------------------------
src/VMF/**
!src/VMF/
!src/VMF/**/
!src/VMF/**/.gitkeep

# --------------------------------------------------
# Python Cache (utility scripts)
# --------------------------------------------------
__pycache__/
*.pyc

# --------------------------------------------------
# .NET SDK and build artifacts
# --------------------------------------------------
.dotnet/
.dotnet-home/
.nuget/
dotnet-install.ps1
**/bin/
**/obj/
.vs/

# --------------------------------------------------
# Publisher local configuration and Google secrets
# --------------------------------------------------
appsettings.local.json
appsettings.*.local.json
appsettings.Local.json
appsettings.*.Local.json
credentials.json
credentials.*.json
client_secret*.json
*oauth-client*.json
*oauth_client*.json
service-account*.json
secrets/
*.pem
*.p12
token-store/
tokens/
*.token.json
```
