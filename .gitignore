```gitignore
# --------------------------------------------------
# Windows
# --------------------------------------------------
Thumbs.db
Desktop.ini

# --------------------------------------------------
# Excel Temporary Files
# --------------------------------------------------
~$*.xls
~$*.xlsx
~$*.xlsm
~$*.xlam
*.tmp

# --------------------------------------------------
# Visual Studio Code
# --------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# --------------------------------------------------
# Logs
# --------------------------------------------------
*.log

# --------------------------------------------------
# Cache
# --------------------------------------------------
.cache/
temp/
tmp/

# --------------------------------------------------
# Backup Files
# --------------------------------------------------
*.bak
*.old
*.orig

# --------------------------------------------------
# Operating System
# --------------------------------------------------
.DS_Store

# --------------------------------------------------
# Build Artifacts (if generated locally)
# --------------------------------------------------
dist/*
!dist/.gitkeep
!dist/build/
!dist/build/.gitkeep
!dist/build/Build.xlam
!dist/release/
!dist/release/.gitkeep
/build/

# --------------------------------------------------
# Python Cache (utility scripts)
# --------------------------------------------------
__pycache__/
*.pyc
```
